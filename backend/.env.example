# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/secureauth
MONGODB_USER=admin
MONGODB_PASSWORD=your_password

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_change_this
JWT_REFRESH_EXPIRE=30d

# Email Configuration (Nodemailer)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_FROM=noreply@secureauth.com

# Security Configuration
OTP_EXPIRE=10
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=15

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Admin Configuration
ADMIN_EMAIL=admin@secureauth.com
ADMIN_PASSWORD=admin_password_change_this
